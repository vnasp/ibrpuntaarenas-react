---
import { Image } from "astro:assets";
import logoHorizontalBlanco from "../assets/logo_horizontal_blanco.png";

const navLinks = [
  { label: "Quiénes Somos", href: "/quienes-somos" },
  { label: "En qué creemos", href: "/en-que-creemos" },
  { label: "Horarios", href: "/horarios" },
  { label: "Contacto", href: "/contacto" },
];

const navLeft = navLinks.slice(0, 2);
const navRight = navLinks.slice(2);

const pathname = Astro.url.pathname;
const isHome = pathname === "/";

function linkClass(href: string) {
  const active = pathname === href || pathname === href + "/";
  return `text-sm tracking-widest uppercase transition-colors duration-200 ${
    active
      ? "text-white font-bold"
      : "text-white/80 hover:text-white hover:font-bold"
  }`;
}
---

<header class={isHome ? "header" : "header-solid"}>
  <div
    class="w-full px-4 md:px-16 lg:px-32 mx-auto flex items-center justify-between lg:h-28
    md:flex-col md:items-center md:h-auto md:py-4 md:gap-6
    lg:flex-row lg:py-0 lg:gap-0"
  >
    <!-- Nav izquierda — solo lg -->
    <nav class="hidden lg:flex items-center gap-16 flex-1">
      {
        navLeft.map((item) => (
          <a href={item.href} class={linkClass(item.href)}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Logo -->
    <a href="/" class="flex items-center select-none" aria-label="Inicio">
      <Image
        src={logoHorizontalBlanco}
        alt="IBR Punta Arenas"
        class="h-24 w-auto object-contain logo"
        loading="eager"
      />
    </a>

    <!-- Nav derecha — solo lg -->
    <nav class="hidden lg:flex items-center gap-16 flex-1 justify-end">
      {
        navRight.map((item) => (
          <a href={item.href} class={linkClass(item.href)}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Nav fila completa — solo md (tablet) -->
    <nav
      class="hidden md:flex lg:hidden items-center gap-16 justify-center flex-wrap"
    >
      {
        navLinks.map((item) => (
          <a href={item.href} class={linkClass(item.href)}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Botón hamburguesa — solo mobile -->
    <button
      id="menu-toggle"
      class="md:hidden text-white p-2 rounded focus:outline-none focus:ring-2 focus:ring-white/40"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="offcanvas-nav"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<!-- Offcanvas overlay -->
<div
  id="offcanvas-overlay"
  class="md:hidden fixed inset-0 z-40 bg-black/50 transition-opacity duration-300 opacity-0 pointer-events-none"
  aria-hidden="true"
>
</div>

<!-- Offcanvas panel -->
<nav
  id="offcanvas-nav"
  aria-label="Menú de navegación"
  aria-hidden="true"
  class="md:hidden fixed top-0 right-0 h-full w-72 max-w-[80vw] bg-primary-deep z-50 transform transition-transform duration-300 ease-in-out flex flex-col translate-x-full"
>
  <div
    class="flex items-center justify-between px-6 py-6 border-b border-white/10"
  >
    <h3 class="text-white">Menú</h3>
    <button
      id="menu-close"
      class="text-white/70 hover:text-white p-1 rounded focus:outline-none focus:ring-2 focus:ring-white/40"
      aria-label="Cerrar menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <ul class="flex flex-col gap-1 p-4 mt-2">
    {
      navLinks.map((item) => {
        const active = pathname === item.href || pathname === item.href + "/";
        return (
          <li>
            <a
              href={item.href}
              class={`block py-3 px-4 rounded text-sm font-medium tracking-wide transition-colors duration-200 ${
                active
                  ? "text-white bg-white/20"
                  : "text-white/80 hover:text-white hover:bg-white/10"
              }`}
            >
              {item.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const close = document.getElementById("menu-close")!;
  const overlay = document.getElementById("offcanvas-overlay")!;
  const panel = document.getElementById("offcanvas-nav")!;

  function openMenu() {
    panel.classList.remove("translate-x-full");
    panel.setAttribute("aria-hidden", "false");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "Cerrar menú");
  }

  function closeMenu() {
    panel.classList.add("translate-x-full");
    panel.setAttribute("aria-hidden", "true");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Abrir menú");
  }

  toggle.addEventListener("click", openMenu);
  close.addEventListener("click", closeMenu);
  overlay.addEventListener("click", closeMenu);
</script>
