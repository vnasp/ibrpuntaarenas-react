---
import CrossDecorator from "./CrossDecorator.astro";

interface Props {
  decoratorText: string;
  mobileDecoratorText?: string;
  title: string;
  subtitle?: string;
  imageSrc: string;
}

const { decoratorText, mobileDecoratorText, title, subtitle, imageSrc } =
  Astro.props;
---

<section
  class="relative w-full h-[55vh] sm:h-[60vh] sm:px-16 md:px-20 lg:px-32 flex items-center"
  aria-label={title}
>
  <img
    src={imageSrc}
    alt=""
    aria-hidden="true"
    width={1536}
    height={1024}
    class="absolute inset-0 w-full h-full object-cover object-center"
  />

  <div class="absolute inset-0 hero-overlay"></div>

  <div class="relative z-10 pt-28 pb-4 sm:pb-8 md:py-24 md:mt-16">
    <div class="hero-enter">
      <CrossDecorator text={decoratorText} mobileText={mobileDecoratorText} />
    </div>
    <h1
      class="font-heading text-white text-4xl sm:text-5xl leading-[1.05] tracking-tight drop-shadow-md hero-enter"
      style="animation-delay: 200ms"
    >
      {title}
    </h1>
    {
      subtitle && (
        <p
          class="mt-7 font-serif italic text-white text-lg sm:text-xl max-w-lg hero-enter"
          style="animation-delay: 380ms"
        >
          {subtitle}
        </p>
      )
    }
  </div>

  <div
    class="absolute left-0 bottom-0 w-full overflow-hidden leading-none rotate-180"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 120"
      class="w-full h-12"
      preserveAspectRatio="none"
    >
      <path
        class="fill-bg"
        d="M0,80L80,90.7C160,101,320,123,480,106.7C640,91,800,37,960,26.7C1120,16,1280,48,1360,64L1440,80L1440,0L0,0Z"
      ></path>
    </svg>
  </div>
</section>
