---
import { Image } from "astro:assets";
import logoBlanco from "../assets/logo_horizontal_blanco.png";
import { services } from "../data/services";

const navLinks = [
  { label: "Quiénes Somos", href: "/quienes-somos" },
  { label: "En qué creemos", href: "/en-que-creemos" },
  { label: "Horarios", href: "/horarios" },
  { label: "Contacto", href: "/contacto" },
];

const year = new Date().getFullYear();
---

<div class="relative bg-primary-deep">
  <div
    class="absolute left-0 -top-10 w-full overflow-hidden leading-none rotate-180"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 120"
      class="w-full h-12"
      preserveAspectRatio="none"
    >
      <path
        class="fill-primary-deep"
        d="M0,80L80,90.7C160,101,320,123,480,106.7C640,91,800,37,960,26.7C1120,16,1280,48,1360,64L1440,80L1440,0L0,0Z"
      ></path>
    </svg>
  </div>

  <footer class="bg-primary-deep text-white">
    <div
      class="w-full px-4 md:px-16 lg:px-32 mx-auto py-14 grid sm:grid-cols-2 md:grid-cols-4 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-10"
    >
      <!-- Columna: Logo + descripción -->
      <div
        class="flex flex-col items-center md:items-start text-center md:text-left"
      >
        <Image
          src={logoBlanco}
          alt="IBR Punta Arenas"
          class="h-20 w-auto object-contain mb-4"
          loading="lazy"
        />
        <p
          class="font-body text-white text-sm leading-relaxed max-w-sm mx-auto md:mx-0"
        >
          Iglesia Bautista Reformada en Punta Arenas, centrada en la Palabra de
          Dios y el evangelio de Jesucristo.
        </p>
        <!-- Redes sociales -->
        <div class="flex gap-4 mt-5">
          <a
            href="https://instagram.com/ibrpuntaarenas"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="text-white/70 hover:text-white transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
          <a
            href="https://facebook.com/ibrpuntaarenas"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="text-white/70 hover:text-white transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna: Navegación -->
      <div>
        <h3
          class="font-heading text-sm uppercase tracking-widest text-white mb-4"
        >
          Navegación
        </h3>
        <ul class="space-y-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-sm text-white hover:text-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna: Horarios -->
      <div>
        <h3
          class="font-heading text-sm uppercase tracking-widest text-white mb-4"
        >
          Horarios
        </h3>
        <ul class="space-y-4 font-body text-sm text-white">
          {
            services.map((s) => (
              <li>
                <span class="block text-white/90 font-medium">
                  {s.day} {s.time}
                </span>
                <span class="text-white">{s.title}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna: Contacto -->
      <div>
        <h3
          class="font-heading text-sm uppercase tracking-widest text-white mb-4"
        >
          Contacto
        </h3>
        <ul class="space-y-4 font-body text-sm text-white">
          <li>
            Ignacio Carrera Pinto 852, Local B<br />
            Punta Arenas, Chile
          </li>
          <li>
            <a
              href="mailto:ibrpuntaarenas@gmail.com"
              class="hover:text-white transition-colors duration-200 break-all lg:text-sm md:text-[10px]"
            >
              ibrpuntaarenas@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Barra inferior -->
    <div class="border-t border-white/10">
      <div
        class="w-full px-4 md:px-16 lg:px-32 mx-auto py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/60 font-body"
      >
        <span>© {year} IBR Punta Arenas. Todos los derechos reservados.</span>
        <span>
          Diseñado por{" "}
          <a
            href="https://linkedin.com/in/vnasp"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white underline underline-offset-2 transition-colors duration-200"
          >
            VM
          </a>
        </span>
      </div>
    </div>
  </footer>
</div>
